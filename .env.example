# Copy to .env in repo root and adjust. Services load from ../../.env via dotenv.

# Shared secrets (all services that issue/verify JWT must match)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# URLs (local dev defaults)
AUTH_SERVICE_URL=http://127.0.0.1:3001
MESSAGES_SERVICE_URL=http://127.0.0.1:3003
CHAT_SERVICE_PUBLIC_URL=http://127.0.0.1:5000

# Auth → Postgres
DATABASE_URL=postgres://webchat:webchat@127.0.0.1:5432/webchat

# Messages → Mongo
MONGO_URI=mongodb://127.0.0.1:27017/webchat

# Redis (chat adapter + presence; optional — chat runs without adapter if unset)
REDIS_URL=redis://127.0.0.1:6379

# Ports
PORT_GATEWAY=4000
PORT_AUTH=3001
PORT_MESSAGES=3003
PORT_CHAT=5000

# CORS (comma-separated origins for gateway + chat)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
